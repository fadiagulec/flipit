{
  "manifest_version": 3,
  "name": "FlipIt — Rate & Flip Posts",
  "short_name": "FlipIt",
  "version": "1.0.0",
  "description": "Rate any Instagram/TikTok/YouTube post for viral potential and flip it into your own viral script — one click, no copy-paste.",
  "author": "FlipIt",
  "homepage_url": "https://flipit.earnwith-ai.com",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["activeTab"],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.youtube.com/*",
    "*://*.linkedin.com/*",
    "*://*.threads.net/*",
    "*://*.facebook.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*"
  ],
  "action": {
    "default_title": "Rate this post with FlipIt",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.instagram.com/*",
        "*://www.tiktok.com/*",
        "*://www.youtube.com/*",
        "*://www.linkedin.com/*",
        "*://www.threads.net/*",
        "*://www.facebook.com/*",
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
